TRADE3_ENV=development
TRADE3_LOG_LEVEL=INFO
TRADE3_OLLAMA_ENABLED=true
TRADE3_OLLAMA_BASE_URL=http://127.0.0.1:11434
TRADE3_OLLAMA_MODEL=qwen3.5:4b
TRADE3_OLLAMA_TIMEOUT_SECONDS=90
TRADE3_OLLAMA_ANALYSIS_CACHE_SECONDS=60
TRADE3_BYBIT_BASE_URL=https://api.bybit.com
TRADE3_BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
TRADE3_BYBIT_REQUEST_TIMEOUT_SECONDS=10
TRADE3_BYBIT_MAX_RETRIES=2
TRADE3_MARKET_MAX_SPREAD_BPS=15
TRADE3_MARKET_MIN_TURNOVER_24H_USDT=15000000
TRADE3_MARKET_MIN_OPEN_INTEREST_USDT=5000000
TRADE3_MARKET_MIN_LISTING_AGE_DAYS=180
TRADE3_MARKET_MAX_ABS_FUNDING_RATE_PCT=0.10
TRADE3_MARKET_MAX_ABS_PRICE_CHANGE_24H_PCT=15
TRADE3_MARKET_ALLOWED_BASE_COINS=BTC,ETH,SOL,XRP,BNB,DOGE,ADA,TRX,HYPE,LINK,BCH,XLM,SUI,AVAX,LTC,TON,DOT,UNI,NEAR,AAVE,XMR,ZEC,ETC,ONDO,TAO,WLD,ENA,1000PEPE,APT,ARB,OP,FIL,ICP,POL,ATOM
TRADE3_MARKET_MAX_SOURCE_AGE_SECONDS=120
TRADE3_MARKET_UNIVERSE_SIZE=20
TRADE3_LIVE_MARKET_DATA_ENABLED=true
TRADE3_LIVE_MAX_MESSAGE_AGE_SECONDS=15
TRADE3_LIVE_MAX_CLOCK_SKEW_SECONDS=5
TRADE3_INTRADAY_MAX_CANDIDATE_SPREAD_BPS=5
TRADE3_INTRADAY_CANDLE_LIMIT=300
TRADE3_INTRADAY_UNIVERSE_REFRESH_SECONDS=1800
TRADE3_INTRADAY_MAX_BACKFILL_CONCURRENCY=4
TRADE3_JOURNAL_ENABLED=false
TRADE3_JOURNAL_DATABASE_PATH=data/trade3_journal.sqlite3
TRADE3_JOURNAL_SCAN_SECONDS=5
TRADE3_JOURNAL_PENDING_EXPIRY_HOURS=6
TRADE3_JOURNAL_ACTIVE_EXPIRY_HOURS=24
TRADE3_JOURNAL_TAKER_FEE_RATE_PCT=0.055
TRADE3_JOURNAL_SLIPPAGE_BPS=2
TRADE3_JOURNAL_MINIMUM_SAMPLE_SIZE=100

# Public market-data access should not require exchange secrets.
# Do not add withdrawal-enabled or order-enabled keys to this project.
